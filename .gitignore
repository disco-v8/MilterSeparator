# Rust
/target/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Configuration (optional - remove if you want to include sample config)
# Example/sample configuration files are kept in `etc/` and tracked.
# Do NOT commit actual runtime configuration files that may contain secrets
# (keep samples like Parameter.conf.sample under version control).

# Include directories that contain samples/templates
!etc/
!logrotate.d/
!systemd/

# Ignore real configuration files with secrets or environment-specific values
etc/MilterSeparator.conf
etc/MilterSeparator.d/Parameter.conf

# NOTE: If these files are already tracked in the repository, stop tracking them with:
#   git rm --cached etc/MilterSeparator.conf etc/MilterSeparator.d/Parameter.conf
# then commit the change so the sensitive files are no longer pushed to remote.

# Build artifacts
*.exe
*.pdb
*.d

# Temporary files
*.tmp
*.temp

# Ensure sample/config templates are tracked even if a '*.d' catch-all exists.
# We ignore runtime-config files but explicitly allow sample/template files below.
!etc/MilterSeparator.d/
!etc/MilterSeparator.d/Parameter.conf.sample
!etc/MilterSeparator.d/templates/
!etc/MilterSeparator.d/templates/*
